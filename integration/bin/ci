#!/bin/bash
set -euo pipefail

INTEGRATION_BIN_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
INTEGRATION_DIR=${INTEGRATION_BIN_DIR%/bin}
cd $INTEGRATION_DIR

# Set base image version
INTEGRATION_VERSIONS=( "2.2" "2.5" "2.7" )
INTEGRATION_APPS=( "rack" )

echo "== Starting CI test suite... =="
echo " - Apps: $INTEGRATION_APPS"
echo " - Versions: $INTEGRATION_VERSIONS"

for app in "${INTEGRATION_APPS[@]}"
do
    : 
    for version in "${INTEGRATION_VERSIONS[@]}"
    do
        :
        # ./bin/test -a $app -v $version
        bash $INTEGRATION_DIR/apps/$app/bin/ci -v $version
    done
done

echo "== Done with CI test suite. =="
